rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // Helper functions
    // ========================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isHouseholdMember(householdId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberIds;
    }

    function isHouseholdAdmin(householdId) {
      return isSignedIn()
        && request.auth.uid == get(/databases/$(database)/documents/households/$(householdId)).data.adminId;
    }

    // ========================================
    // Users collection
    // ========================================

    match /users/{userId} {
      // Users can read their own profile; any signed-in user can read others' profiles
      // (needed for getHouseholdMembers when joining or viewing household)
      allow read: if isSignedIn();

      // Any signed-in user can create their own profile
      allow create: if isSignedIn() && isOwner(userId);

      // Users can update their own profile
      allow update: if isSignedIn() && isOwner(userId);

      allow delete: if isSignedIn() && isOwner(userId);

      // User preferences subcollection
      match /settings/{settingId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }
    }

    // ========================================
    // Households collection
    // ========================================

    match /households/{householdId} {
      // Any authenticated user can read households (needed for invite code lookup)
      allow read: if isSignedIn();

      // Any authenticated user can create a household (they become admin)
      allow create: if isSignedIn()
        && request.resource.data.adminId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;

      // Admin can update household settings
      // OR any signed-in user can join by adding themselves to memberIds
      allow update: if isSignedIn() && (
        isHouseholdAdmin(householdId)
        || (
          // Joining: only memberIds changes, user is adding themselves
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
          && request.auth.uid in request.resource.data.memberIds
          && !(request.auth.uid in resource.data.memberIds)
        )
      );

      // Only admin can delete household
      allow delete: if isHouseholdAdmin(householdId);

      // ----------------------------------------
      // Meals subcollection
      // ----------------------------------------

      match /meals/{mealId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdMember(householdId);
        allow update: if isHouseholdMember(householdId);
        allow delete: if isHouseholdMember(householdId);
      }

      // ----------------------------------------
      // Dishes subcollection
      // ----------------------------------------

      match /dishes/{dishId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdMember(householdId);
        allow update: if isHouseholdMember(householdId);
        allow delete: if isHouseholdAdmin(householdId);
      }

      // ----------------------------------------
      // Restaurants subcollection
      // ----------------------------------------

      match /restaurants/{restaurantId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdMember(householdId);
        allow update: if isHouseholdMember(householdId);
        allow delete: if isHouseholdAdmin(householdId);
      }
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
